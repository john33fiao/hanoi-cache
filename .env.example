# 로컬 개발용 예시 환경 변수 파일입니다.
# 애플리케이션은 시작 시 현재 작업 디렉터리의 `.env`를 자동으로 읽습니다.
# 같은 키가 셸 환경 변수에 이미 있으면 셸 값이 우선합니다.

# OpenWeatherMap 폴백용 API 키입니다.
# 폴백 경로를 거의 사용하지 않더라도 서버 시작 시 이 값이 필요합니다.
OPENWEATHERMAP_API_KEY=your-openweathermap-api-key

# 서버가 바인딩할 HTTP 포트입니다.
# 비워 두면 애플리케이션은 기본값 `3000`을 사용합니다.
PORT=3000

# Rust tracing 로그 레벨 필터입니다.
# 일반적으로 `error`, `warn`, `info`, `debug`, `trace` 값을 사용합니다.
RUST_LOG=info
